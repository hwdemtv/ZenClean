{
  "_comment": "ZenClean 本地 AI 知识库 v1.0.0 — 规则按优先级从高到低排列，第一个命中的规则生效。",
  "version": "1.0.0",
  "rules": [
    {
      "id": "sys_temp_001",
      "description": "Windows 系统临时目录",
      "pattern": "^[Cc]:\\\\Windows\\\\Temp\\\\",
      "risk_level": "LOW",
      "category": "system_temp",
      "ai_advice": "Windows 系统临时文件，程序运行后的残余，安全可清理。",
      "is_checked_default": true
    },
    {
      "id": "user_temp_001",
      "description": "用户级临时目录 (%TEMP%)",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Temp\\\\",
      "risk_level": "LOW",
      "category": "system_temp",
      "ai_advice": "用户临时文件（%TEMP%），程序运行残留，安全可清理。",
      "is_checked_default": true
    },
    {
      "id": "win_prefetch_001",
      "description": "Windows 预读取缓存",
      "pattern": "^[Cc]:\\\\Windows\\\\Prefetch\\\\.*\\.pf$",
      "risk_level": "LOW",
      "category": "system_temp",
      "ai_advice": "Windows 程序预读取记录，删除后首次启动对应程序略慢，无数据风险。",
      "is_checked_default": true
    },
    {
      "id": "win_errorreports_001",
      "description": "Windows 错误报告缓存",
      "pattern": "^[Cc]:\\\\(Users\\\\[^\\\\]+\\\\AppData\\\\Local|ProgramData)\\\\Microsoft\\\\Windows\\\\WER\\\\",
      "risk_level": "LOW",
      "category": "system_temp",
      "ai_advice": "Windows 错误报告转储文件，无个人数据价值，安全可清理。",
      "is_checked_default": true
    },
    {
      "id": "chrome_cache_001",
      "description": "Google Chrome 浏览器缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data\\\\[^\\\\]+\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "browser_cache",
      "ai_advice": "Chrome 浏览器网页缓存，删除后首次访问网页略慢，无数据损失风险。",
      "is_checked_default": true
    },
    {
      "id": "edge_cache_001",
      "description": "Microsoft Edge 浏览器缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Microsoft\\\\Edge\\\\User Data\\\\[^\\\\]+\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "browser_cache",
      "ai_advice": "Edge 浏览器网页缓存，删除后首次访问网页略慢，无数据损失风险。",
      "is_checked_default": true
    },
    {
      "id": "firefox_cache_001",
      "description": "Mozilla Firefox 浏览器缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Mozilla\\\\Firefox\\\\Profiles\\\\[^\\\\]+\\\\cache2\\\\",
      "risk_level": "LOW",
      "category": "browser_cache",
      "ai_advice": "Firefox 浏览器网页缓存，删除后首次访问网页略慢，无数据损失风险。",
      "is_checked_default": true
    },
    {
      "id": "wechat_cache_001",
      "description": "微信文件加载缓存（安全子目录）",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\Documents\\\\WeChat Files\\\\[^\\\\]+\\\\FileStorage\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "social_cache",
      "ai_advice": "微信图片/文件加载缓存，仅限 Cache 子目录，不含聊天记录与媒体文件。",
      "is_checked_default": true
    },
    {
      "id": "qq_cache_001",
      "description": "QQ 图片加载缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\Documents\\\\Tencent Files\\\\[^\\\\]+\\\\Image\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "social_cache",
      "ai_advice": "QQ 图片加载缓存，不含聊天记录，安全可清理。",
      "is_checked_default": true
    },
    {
      "id": "pip_cache_001",
      "description": "Python pip 包缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\pip\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "dev_cache",
      "ai_advice": "Python pip 下载缓存，删除后重新安装包时需重新下载，不影响已安装的环境。",
      "is_checked_default": true
    },
    {
      "id": "npm_cache_001",
      "description": "npm 全局包缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Roaming\\\\npm-cache\\\\",
      "risk_level": "LOW",
      "category": "dev_cache",
      "ai_advice": "npm 包下载缓存，删除后重新安装时需重新下载，不影响已安装的 node_modules。",
      "is_checked_default": true
    },
    {
      "id": "spotify_cache_001",
      "description": "Spotify 音乐缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Spotify\\\\Storage\\\\",
      "risk_level": "LOW",
      "category": "app_cache",
      "ai_advice": "Spotify 音乐流媒体缓存，删除后重新播放时需重新缓冲，无数据损失风险。",
      "is_checked_default": true
    },
    {
      "id": "win_update_001",
      "description": "Windows Update 下载缓存",
      "pattern": "^[Cc]:\\\\Windows\\\\SoftwareDistribution\\\\Download\\\\",
      "risk_level": "MEDIUM",
      "category": "windows_update",
      "ai_advice": "Windows Update 下载缓存，清理后重新检测更新时需重新下载安装包，建议更新完成后再清理。",
      "is_checked_default": false
    },
    {
      "id": "recycle_bin_001",
      "description": "回收站文件",
      "pattern": "^[Cc]:\\\\\\$Recycle\\.Bin\\\\",
      "risk_level": "MEDIUM",
      "category": "recycle_bin",
      "ai_advice": "回收站中的文件，如确认不需要恢复可清理。建议用户自行逐项确认后删除。",
      "is_checked_default": false
    },
    {
      "id": "wechat_media_001",
      "description": "微信接收的媒体与文件（高危，默认不勾选）",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\Documents\\\\WeChat Files\\\\[^\\\\]+\\\\FileStorage\\\\(Image|Video|File)\\\\",
      "risk_level": "HIGH",
      "category": "social_media",
      "ai_advice": "警告：此目录包含微信接收的图片、视频或文件，误删将导致不可逆丢失！仅在明确不需要时勾选。",
      "is_checked_default": false
    },
    {
      "id": "node_modules_cache_001",
      "description": "Node.js 项目构建缓存（VIP 分类，第一阶段收录但置灰显示）",
      "pattern": "^[Cc]:\\\\.*\\\\node_modules\\\\.cache\\\\",
      "risk_level": "MEDIUM",
      "category": "dev_build_cache",
      "ai_advice": "Node.js 构建工具缓存（如 webpack/vite），删除后首次构建需重新生成，不影响源代码。",
      "is_checked_default": false
    },
    {
      "id": "win_logs_001",
      "description": "Windows 系统日志文件",
      "pattern": "^[Cc]:\\\\Windows\\\\Logs\\\\",
      "risk_level": "LOW",
      "category": "system_logs",
      "ai_advice": "系统运行产生的历史日志，普通用户清理后不影响使用。",
      "is_checked_default": true
    },
    {
      "id": "win_installer_cache_001",
      "description": "系统临时安装补丁",
      "pattern": "^[Cc]:\\\\Windows\\\\Installer\\\\\\$PatchCache\\\\",
      "risk_level": "LOW",
      "category": "system_temp",
      "ai_advice": "Windows 安装程序留下的补丁缓存，可以安全清理以释放空间。",
      "is_checked_default": true
    },
    {
      "id": "lark_cache_001",
      "description": "飞书本地缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Feishu\\\\.*\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "social_cache",
      "ai_advice": "飞书客户端产生的图片及文档加载缓存，清理后重新查看历史消息时会重新下载。",
      "is_checked_default": true
    },
    {
      "id": "dingtalk_cache_001",
      "description": "钉钉本地缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Roaming\\\\DingTalk\\\\.*\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "social_cache",
      "ai_advice": "钉钉客户端的各类图片、缓存文件，清理不影响聊天记录数据本身。",
      "is_checked_default": true
    },
    {
      "id": "netease_music_001",
      "description": "网易云音乐缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Local\\\\Netease\\\\CloudMusic\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "app_cache",
      "ai_advice": "网易云音乐播放缓存，删除后听曾经听过的歌需要重新加载。",
      "is_checked_default": true
    },
    {
      "id": "bilibili_cache_001",
      "description": "哔哩哔哩客户端缓存",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\AppData\\\\Roaming\\\\bilibili\\\\.*\\\\Cache\\\\",
      "risk_level": "LOW",
      "category": "app_cache",
      "ai_advice": "B站 PC 端视频和图片加载缓存，可安全清理。",
      "is_checked_default": true
    },
    {
      "id": "downloads_folder_001",
      "description": "系统下载目录 (高危，默认不勾选)",
      "pattern": "^[Cc]:\\\\Users\\\\[^\\\\]+\\\\Downloads\\\\",
      "risk_level": "HIGH",
      "category": "downloads",
      "ai_advice": "警告：这是系统的默认下载文件夹。清理前请必须确认没有重要的下载件！",
      "is_checked_default": false
    }
  ]
}